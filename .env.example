# Environment variables for the Python server
PORT=3000
UVICORN_RELOAD=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sbp

# Seqera Platform configuration
SEQERA_API_URL=https://api.example.com
SEQERA_ACCESS_TOKEN=replace-me
COMPUTE_ID=compute-env-id
WORK_SPACE=workspace-id
WORK_DIR=s3://bucket/workdir

# AWS S3 Configuration for file uploads
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=your-private-bucket-name

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Workflow execution role guard
# Users must hold WORKFLOW_EXECUTION_ROLE (found under AUTH0_ROLES_CLAIM in the access token) to launch workflows.
# If either value is unset, the launch endpoint denies all requests.
AUTH0_ROLES_CLAIM=https://biocommons.org.au/roles
WORKFLOW_EXECUTION_ROLE=biocommons/group/sbp_workflow_execution

# Auth provider configuration
AUTH_DOMAIN=your-auth-domain.example.com
AUTH_CLIENT_ID=your-auth-client-id
AUTH_AUDIENCE=https://your-auth-audience.example.com

# Optional DB debugging UI (Starlette Admin)
ENABLE_DB_ADMIN=false
DB_ADMIN_TITLE=SBP Backend Admin
DB_ADMIN_COOKIE_SECURE=true
DB_ADMIN_REQUIRED_ROLE=biocommons/role/sbp/admin
DB_ADMIN_ROLES_CLAIM=https://biocommons.org.au/roles
# Required when ENABLE_DB_ADMIN=true. Set a strong random value.
DB_ADMIN_SESSION_SECRET=change-me-to-a-long-random-secret
DB_ADMIN_FORBIDDEN_HOME_URL=/

# Required when ENABLE_DB_ADMIN=true.
# Must be added as an allowed callback URL in your auth provider app settings.
DB_ADMIN_AUTH_REDIRECT_URI=http://localhost:3000/admin/login

# System status / health probes (drives the admin "System Status" dashboard)
# Cache TTL (seconds) for the Seqera API + compute-env probes. Default: 30.
HEALTH_CACHE_TTL_SECONDS=30
# Active Tower Agent liveness check. When true, the status probes additionally
# clone COMPUTE_ID into a throwaway compute env (forcing Seqera to validate the
# agent connection) and delete it. This MUTATES Seqera state (creates/deletes a
# compute env on every probe), so it is opt-in. Default: false.
ENABLE_AGENT_HEALTHCHECK=false
# Max seconds to wait for the throwaway env to validate before reporting degraded.
HEALTHCHECK_AGENT_TIMEOUT_SECONDS=20
# Optional: backend CloudWatch log group name. When set, the admin dashboard
# shows a one-click link to it for drilling into Seqera API errors.
SBP_BACKEND_LOG_GROUP=
